body {
    margin: 0;
    font-family: 'Segoe UI';
    background: linear-gradient(to right, #e3f2fd, #fce4ec);
}

/* HEADER */
header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

input {
    padding: 8px;
    width: 200px;
}

nav button {
    margin: 5px;
    padding: 8px;
    border: none;
    background: #2196F3;
    color: white;
    border-radius: 5px;
}

/* PRODUCTS */
.products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
    padding: 20px;
    gap: 20px;
}

.product {
    background: white;
    padding: 15px;
    border-radius: 10px;
    text-align: center;
}

.product button {
    background: #4CAF50;
    border: none;
    padding: 10px;
    color: white;
    width: 100%;
}

/* CART */
#cart-panel {
    position: fixed;
    right: -300px;
    top: 0;
    width: 300px;
    height: 100%;
    background: white;
    padding: 20px;
    transition: 0.3s;
}

#cart-panel.active {
    right: 0;
}

/* LOGIN */
#login-box {
    position: fixed;
    left: 20px;
    bottom: 20px;
    background: white;
    padding: 15px;
    border-radius: 10px;
}
